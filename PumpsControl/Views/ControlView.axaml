<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:PumpsControl.ViewModels"
             x:DataType="vm:ControlViewModel"
             mc:Ignorable="d" d:DesignWidth="950" d:DesignHeight="450"
             x:Class="PumpsControl.Views.ControlView">
    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
         to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:DesignPreviewViewModel />
    </Design.DataContext>
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>Auto,Auto,Auto</Grid.ColumnDefinitions>
                <!-- Control Pump P001 -->
                <HeaderedContentControl Header="Pump P001" Classes="groupBox" Width="250" VerticalAlignment="Center"
                                        Margin="60,0,0,0">
                    <StackPanel Orientation="Vertical">
                        <Image Source="../Assets/Images/technology.png" Width="100" StretchDirection="Both" />
                        <!-- Motor Status -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Ellipse Fill="Green" Width="14" Height="14" Margin="0,0,10,0" />
                            <TextBlock>
                                <Run Text="Status:" />
                                <Run Text="Stopped" />
                            </TextBlock>
                        </StackPanel>
                        <!-- Fault Status -->
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Center">
                            <Ellipse Fill="Green" Width="14" Height="14" Margin="0,0,10,0" />
                            <TextBlock>
                                <Run Text="Fault:" />
                                <Run Text="Healthy" />
                            </TextBlock>
                        </StackPanel>
                        <!-- Frequency SetPoint -->
                        <TextBlock Margin="0,10,0,0" HorizontalAlignment="Center">
                            <Run Text="SetPoint:" />
                            <Run Text="{Binding CurrentFrequencyValue}" />
                            <Run Text="Hz" />
                        </TextBlock>
                        <!-- Current Frequency Indicator -->
                        <TextBlock Margin="0,10,0,0" HorizontalAlignment="Center">
                            <Run Text="Frequency:" />
                            <Run Text="{Binding CurrentFrequencyValue}" />
                            <Run Text="Hz" />
                        </TextBlock>
                        <TextBlock Classes="textBlockSettings"
                                   Margin="0,20,0,2"
                                   Text="Frequency SetPoint" />
                        <TextBox Watermark="e.g 50.5"
                                 HorizontalContentAlignment="Center"
                                 Text="{Binding FrequencyValue}" />
                        <Button Classes="primaryButton"
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                Content="Write Frequency"
                                Command="{Binding WriteDataControlPumpCommand}" />
                        <!-- Control Buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Center" >
                            <Button Classes="primaryButton"
                                    Content="Run"
                                    Command="{Binding WriteBitStartPumpCommand}" />
                            <Button Classes="primaryButton"
                                    Content="Stop"
                                    Command="{Binding WriteBitStopPumpCommand}" />
                            <Button Classes="primaryButton"
                                    Content="Reset"
                                    Command="{Binding WriteBitStopPumpCommand}" />
                        </StackPanel>
                    </StackPanel>
                </HeaderedContentControl>
                <!-- Control Pump P001 -->
                <HeaderedContentControl Grid.Column="1" Header="Pump P001" Classes="groupBox" Width="250"
                                        VerticalAlignment="Center" Margin="40,0,0,0">
                    <StackPanel Orientation="Vertical">
                        <Image Source="../Assets/Images/technology.png" Width="100" StretchDirection="Both" />
                        <!-- Motor Status -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Ellipse Fill="Green" Width="14" Height="14" Margin="0,0,10,0" />
                            <TextBlock>
                                <Run Text="Status:" />
                                <Run Text="Stopped" />
                            </TextBlock>
                        </StackPanel>
                        <!-- Fault Status -->
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Center">
                            <Ellipse Fill="Green" Width="14" Height="14" Margin="0,0,10,0" />
                            <TextBlock>
                                <Run Text="Fault:" />
                                <Run Text="Healthy" />
                            </TextBlock>
                        </StackPanel>
                        <!-- Frequency SetPoint -->
                        <TextBlock Margin="0,10,0,0" HorizontalAlignment="Center">
                            <Run Text="SetPoint:" />
                            <Run Text="{Binding CurrentFrequencyValue}" />
                            <Run Text="Hz" />
                        </TextBlock>
                        <!-- Current Frequency Indicator -->
                        <TextBlock Margin="0,10,0,0" HorizontalAlignment="Center">
                            <Run Text="Frequency:" />
                            <Run Text="{Binding CurrentFrequencyValue}" />
                            <Run Text="Hz" />
                        </TextBlock>
                        <TextBlock Classes="textBlockSettings"
                                   Margin="0,20,0,2"
                                   Text="Frequency SetPoint" />
                        <TextBox Watermark="e.g 50.5"
                                 HorizontalContentAlignment="Center"
                                 Text="{Binding FrequencyValue}" />
                        <Button Classes="primaryButton"
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                Content="Write Frequency"
                                Command="{Binding WriteDataControlPumpCommand}" />
                        <!-- Control Buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Center">
                            <Button Classes="primaryButton"
                                    Content="Run"
                                    Command="{Binding WriteBitStartPumpCommand}" />
                            <Button Classes="primaryButton"
                                    Content="Stop"
                                    Command="{Binding WriteBitStopPumpCommand}" />
                            <Button Classes="primaryButton"
                                    Content="Reset"
                                    Command="{Binding WriteBitStopPumpCommand}" />
                        </StackPanel>
                    </StackPanel>
                </HeaderedContentControl>
                 <!-- Control Pump P001 -->
                <HeaderedContentControl Grid.Column="2" Header="Pump P001" Classes="groupBox" Width="250"
                                        VerticalAlignment="Center" Margin="40,0,0,0">
                    <StackPanel Orientation="Vertical">
                        <Image Source="../Assets/Images/technology.png" Width="100" StretchDirection="Both" />
                        <!-- Motor Status -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Ellipse Fill="Green" Width="14" Height="14" Margin="0,0,10,0" />
                            <TextBlock>
                                <Run Text="Status:" />
                                <Run Text="Stopped" />
                            </TextBlock>
                        </StackPanel>
                        <!-- Fault Status -->
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Center">
                            <Ellipse Fill="Green" Width="14" Height="14" Margin="0,0,10,0" />
                            <TextBlock>
                                <Run Text="Fault:" />
                                <Run Text="Healthy" />
                            </TextBlock>
                        </StackPanel>
                        <!-- Frequency SetPoint -->
                        <TextBlock Margin="0,10,0,0" HorizontalAlignment="Center">
                            <Run Text="SetPoint:" />
                            <Run Text="{Binding CurrentFrequencyValue}" />
                            <Run Text="Hz" />
                        </TextBlock>
                        <!-- Current Frequency Indicator -->
                        <TextBlock Margin="0,10,0,0" HorizontalAlignment="Center">
                            <Run Text="Frequency:" />
                            <Run Text="{Binding CurrentFrequencyValue}" />
                            <Run Text="Hz" />
                        </TextBlock>
                        <TextBlock Classes="textBlockSettings"
                                   Margin="0,20,0,2"
                                   Text="Frequency SetPoint" />
                        <TextBox Watermark="e.g 50.5"
                                 HorizontalContentAlignment="Center"
                                 Text="{Binding FrequencyValue}" />
                        <Button Classes="primaryButton"
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                Content="Write Frequency"
                                Command="{Binding WriteDataControlPumpCommand}" />
                        <!-- Control Buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Center">
                            <Button Classes="primaryButton"
                                    Content="Run"
                                    Command="{Binding WriteBitStartPumpCommand}" />
                            <Button Classes="primaryButton"
                                    Content="Stop"
                                    Command="{Binding WriteBitStopPumpCommand}" />
                            <Button Classes="primaryButton"
                                    Content="Reset"
                                    Command="{Binding WriteBitStopPumpCommand}" />
                        </StackPanel>
                    </StackPanel>
                </HeaderedContentControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>