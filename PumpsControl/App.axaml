<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:PumpsControl"
             x:Class="PumpsControl.App"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />

        <!-- Custom Styles -->
        <StyleInclude Source="avares://PumpsControl/Assets/Styles/Buttons.axaml" />
        <StyleInclude Source="avares://PumpsControl/Assets/Styles/Controls.axaml" />
        <StyleInclude Source="avares://PumpsControl/Assets/Styles/Icons.axaml" />
        <StyleInclude Source="avares://PumpsControl/Assets/Styles/GroupBox.axaml" />
    </Application.Styles>
</Application>